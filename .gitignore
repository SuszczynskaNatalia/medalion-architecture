# Środowisko wirtualne
venv/
.venv/
dbt_venv/

# Pliki tymczasowe Pythona
__pycache__/
*.pyc
*.pyo
*.pyd

data/*
!data/.gitkeep
!data/exports/
!data/exports/**

.env

# ==========================================
# DBT (Data Build Tool) ARTIFACTS
# ==========================================
# Ignorujemy skompilowane pliki SQL, logi i pobrane paczki
dbt/target/
dbt/dbt_packages/
dbt/logs/

# ==========================================
# AIRFLOW & DOCKER ARTIFACTS
# ==========================================
logs/*
!logs/.gitkeep
airflow.cfg
webserver_config.py
postgres-data/

# ==========================================
# PLIKI LOKALNE / TYMCZASOWE
# ==========================================
*.duckdb
*.duckdb.wal
dbt/.user.yml
_run_docker_test.py

# Skrypty do lokalnego testowania (bez Snowflake / jednorazowe)
scripts/_*.py

# Szablony robocze ODT
__Data_Product_Card_Template__.odt

# dbt auto-generuje pusty README przy inicjalizacji projektu
dbt/README.md

# Tymczasowe pliki blokady MS Office / LibreOffice
~$*

# Wersje pośrednie kart ODT (śledzimy tylko finalną w docs/)
docs/*_v[0-9]*.odt
docs/*_v[0-9][0-9]*.odt

